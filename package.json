{
  "name": "registry",
  "version": "0.3.1",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "pnpm run readmes:generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "audit:composition": "node scripts/audit-composition.mjs",
    "audit:standalone": "node scripts/audit-standalone.mjs",
    "test:unit": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test tests/*.test.ts",
    "dendrite:sync": "node scripts/dendrite-catalog.mjs",
    "registry:build": "shadcn build",
    "registry:check": "node scripts/check-registry-drift.mjs",
    "registry:validate": "node scripts/validate-registry-capabilities.mjs",
    "registry:smoke": "node scripts/smoke-registry-install.mjs",
    "registry:smoke:base": "AURORA_REGISTRY_SMOKE_PROFILES=base node scripts/smoke-registry-install.mjs",
    "tokens:export": "node scripts/export-aurora-tokens.mjs",
    "tokens:generate": "node scripts/export-aurora-tokens.mjs && node android/sd.config.mjs",
    "readmes:generate": "node scripts/generate-readmes.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-context-menu": "^2.3.3",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^20.19.9",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "css-tree": "3.2.1",
    "eslint": "^9.32.0",
    "eslint-config-next": "16.2.10",
    "style-dictionary": "4.0.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.2",
    "storybook": "^10.5.0",
    "@storybook/nextjs-vite": "^10.5.0",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "vite": "^8.1.4",
    "eslint-plugin-storybook": "^10.5.0"
  }
}
