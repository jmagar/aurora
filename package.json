{
  "name": "registry",
  "version": "0.4.3",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "pnpm run generated:check && pnpm run readmes:generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "audit:composition": "node scripts/audit-composition.mjs",
    "audit:standalone": "node scripts/audit-standalone.mjs",
    "test:unit": "node --test tests/*.test.ts",
    "test:coverage": "c8 --all --include='app/**/*.{ts,tsx}' --include='components/**/*.{ts,tsx}' --include='lib/**/*.{ts,tsx}' --include='registry/aurora/**/*.{ts,tsx}' --include='scripts/*.mjs' --include='proxy.ts' --exclude='**/*.stories.tsx' --exclude='app/gallery/demos/**' --exclude='app/gallery/entries/**' --exclude='lib/*.json' --exclude='lib/preview-poster.tsx' --exclude='registry/aurora/examples/**' --reporter=text --reporter=json-summary --check-coverage --lines=3 --functions=5 --branches=12 --statements=3 node --test tests/*.test.ts",
    "test:e2e": "playwright test",
    "performance:check": "node scripts/check-web-performance.mjs",
    "test:storybook": "playwright test --project=storybook-chromium",
    "dendrite:sync": "node scripts/dendrite-catalog.mjs",
    "registry:build": "shadcn build",
    "registry:check": "node scripts/check-registry-drift.mjs",
    "registry:validate": "node scripts/validate-registry-capabilities.mjs",
    "registry:graph": "node scripts/validate-registry-graph.mjs",
    "registry:smoke": "node scripts/smoke-registry-install.mjs",
    "registry:smoke:base": "AURORA_REGISTRY_SMOKE_PROFILES=base node scripts/smoke-registry-install.mjs",
    "tokens:export": "node scripts/export-aurora-tokens.mjs",
    "tokens:generate": "node scripts/export-aurora-tokens.mjs && node android/sd.config.mjs",
    "readmes:generate": "node scripts/generate-readmes.mjs",
    "gallery:generate": "node scripts/generate-gallery-entries.mjs",
    "gallery:check": "node scripts/generate-gallery-entries.mjs --check",
    "catalog:generate": "node scripts/generate-client-catalog.mjs",
    "catalog:check": "node scripts/generate-client-catalog.mjs --check",
    "generated:generate": "pnpm gallery:generate && pnpm catalog:generate",
    "generated:check": "node scripts/check-generated-artifacts.mjs",
    "skill:sync": "node scripts/sync-agent-skill.mjs",
    "skill:check": "node scripts/sync-agent-skill.mjs --check && ops/check-skill-sync.sh",
    "refs:check": "node scripts/migrate-react19-refs.mjs --check",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-context-menu": "^2.3.3",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-hover-card": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-menubar": "^1.1.20",
    "@radix-ui/react-navigation-menu": "^1.2.18",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.11",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.13.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/nextjs-vite": "^10.5.2",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "c8": "^12.0.0",
    "css-tree": "3.2.1",
    "eslint": "^9.32.0",
    "eslint-config-next": "16.2.11",
    "eslint-plugin-storybook": "^10.5.2",
    "openwiki": "0.1.2",
    "storybook": "^10.5.2",
    "style-dictionary": "5.5.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "vite": "^8.1.5"
  }
}
