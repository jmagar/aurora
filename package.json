{
  "name": "registry",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "pnpm run readmes:generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "audit:composition": "node scripts/audit-composition.mjs",
    "audit:standalone": "node scripts/audit-standalone.mjs",
    "test:unit": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test tests/*.test.ts",
    "registry:build": "shadcn build",
    "tokens:export": "node scripts/export-aurora-tokens.mjs",
    "tokens:generate": "node scripts/export-aurora-tokens.mjs && node android/sd.config.mjs",
    "readmes:generate": "node scripts/generate-readmes.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.487.0",
    "next": "16.2.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.19.9",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "css-tree": "3.2.1",
    "eslint": "^9.32.0",
    "eslint-config-next": "16.2.6",
    "style-dictionary": "4.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.2",
    "storybook": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "vite": "^8.0.16",
    "eslint-plugin-storybook": "^10.4.6"
  }
}
