{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "aurora-gateway",
  "title": "Aurora Gateway Page",
  "author": "jmagar <https://github.com/jmagar>",
  "description": "Starter gateway operations page using Aurora cards, badges, buttons, and timeline primitives.",
  "dependencies": [],
  "registryDependencies": [
    "@aurora/aurora-base",
    "@aurora/aurora-card",
    "@aurora/aurora-timeline",
    "@aurora/aurora-badge",
    "@aurora/aurora-button"
  ],
  "files": [
    {
      "path": "registry/aurora/pages/gateway/page.tsx",
      "content": "import { Badge } from \"@/registry/aurora/ui/badge\"\nimport { Button } from \"@/registry/aurora/ui/button\"\nimport { Card, CardDescription, CardHeader, CardTitle } from \"@/registry/aurora/ui/card\"\nimport { Timeline, TimelineItem } from \"@/registry/aurora/ui/timeline\"\n\nexport default function AuroraGatewayPage() {\n  return (\n    <main className=\"aurora-page-shell min-h-screen p-6\">\n      <div className=\"mx-auto grid max-w-6xl gap-5 lg:grid-cols-[1fr_360px]\">\n        <section className=\"flex flex-col gap-4\">\n          <div className=\"flex items-center justify-between gap-3\">\n            <div>\n              <p className=\"aurora-text-eyebrow\">Aurora starter</p>\n              <h1 className=\"aurora-text-display-2\">Gateway operations</h1>\n            </div>\n            <Button variant=\"aurora\">Run health check</Button>\n          </div>\n          <div className=\"grid gap-4 md:grid-cols-3\">\n            {[\n              [\"Connected tools\", \"42\"],\n              [\"Queued jobs\", \"8\"],\n              [\"Warnings\", \"2\"],\n            ].map(([label, value]) => (\n              <Card key={label}>\n                <CardHeader>\n                  <CardTitle>{value}</CardTitle>\n                  <CardDescription>{label}</CardDescription>\n                </CardHeader>\n              </Card>\n            ))}\n          </div>\n        </section>\n        <Card>\n          <CardHeader>\n            <CardTitle>Activity</CardTitle>\n            <CardDescription>Recent gateway events</CardDescription>\n          </CardHeader>\n          <div className=\"flex flex-col gap-3 px-6 pb-6\">\n            <Badge tone=\"success\">All systems nominal</Badge>\n            <Timeline>\n              <TimelineItem tone=\"online\" title=\"Registry smoke passed\">\n                aurora-base installed cleanly.\n              </TimelineItem>\n              <TimelineItem tone=\"online\" title=\"Gateway sync complete\">\n                42 upstream tools available.\n              </TimelineItem>\n            </Timeline>\n          </div>\n        </Card>\n      </div>\n    </main>\n  )\n}\n",
      "type": "registry:file",
      "target": "app/aurora/gateway/page.tsx"
    }
  ],
  "meta": {
    "namespace": "@aurora",
    "style": "aurora",
    "family": "page",
    "starter": "gateway"
  },
  "docs": "Starter page for an Aurora gateway workspace. Installs to `app/aurora/gateway/page.tsx` and depends on `aurora-base`.",
  "categories": [
    "aurora",
    "page",
    "starter"
  ],
  "type": "registry:page"
}