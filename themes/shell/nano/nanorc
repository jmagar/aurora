# Enable syntax highlighting for all available languages
include "/usr/share/nano/*.nanorc"

# UI improvements
set linenumbers          # Show line numbers
set mouse                # Enable mouse support
set softwrap             # Wrap long lines at word boundaries
set tabsize 4            # Set tab size to 4 spaces
set tabstospaces         # Convert tabs to spaces
set constantshow         # Always show cursor position

# Search improvements
set casesensitive        # Case-sensitive search by default
set regexp               # Enable regex search by default

# Auto-indent
set autoindent

# History and position
set historylog           # Save search/replace history
set positionlog          # Remember cursor position in files

# Editing improvements
set atblanks             # Wrap at blank characters
set trimblanks           # Trim trailing whitespace on save
set zap                  # Make Backspace/Delete erase selected text

# Show whitespace
# set whitespace "»·"    # Uncomment to visualize tabs and spaces

# JSON file associations
# Extend JSON syntax to common JSON config files
extendsyntax json header "\.(jsonc|json5|babelrc|eslintrc|prettierrc|bowerrc|jshintrc)$"
extendsyntax json header "(^|/)(\.|)[a-z]*rc$"

# =============================================================================
# Aurora interface colors. NOTE: this nano build (--enable-utf8 only) accepts
# only named colors — no #hex or 256-index — so these are nano's nearest named
# matches to the Aurora palette (cyan/teal/pink/ocher/slate/lagoon).
# Syntax highlighting itself comes from the included /usr/share/nano/*.nanorc.
# =============================================================================
set titlecolor     bold,black,cyan   # title bar    — dark on cyan
set promptcolor    white,black       # prompt line  — white on dark
set statuscolor    bold,black,teal   # status msgs  — dark on teal
set errorcolor     bold,black,rosy   # errors       — dark on dusty rose
set minicolor      white,black       # minibar      — white on dark
set selectedcolor  white,slate       # selection    — white on slate
set spotlightcolor black,ocher       # search match — dark on amber
set stripecolor    slate             # column guide
set scrollercolor  lagoon            # scrollbar    — deep blue/teal
set numbercolor    slate             # line numbers — dim
set keycolor       cyan              # shortcut keys (^G)
set functioncolor  grey              # shortcut labels — muted
