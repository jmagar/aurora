<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Aurora — bat / Sublime tmTheme.
  Matches ~/.claude/themes/aurora.json, the Aurora statusline, p10k, eza & FSH.
  Tokens: navy #07131C bg · white #E6F4FB · cyan #29B6F6 · cyan+ #67CBFA
          rose #F9A8C4 · violet #A78BFA · teal #7DD3C7 · amber #C6A36B
          muted #A7BCC9 · dim #3D6070 · error #C78490 · deep-blue #1C7FAC
-->
<plist version="1.0">
<dict>
  <key>name</key>
  <string>Aurora</string>
  <key>settings</key>
  <array>

    <!-- Editor / global -->
    <dict>
      <key>settings</key>
      <dict>
        <key>background</key><string>#07131C</string>
        <key>foreground</key><string>#E6F4FB</string>
        <key>caret</key><string>#29B6F6</string>
        <key>lineHighlight</key><string>#102330</string>
        <key>selection</key><string>#1E4560</string>
        <key>selectionForeground</key><string>#E6F4FB</string>
        <key>invisibles</key><string>#3D6070</string>
        <key>gutter</key><string>#07131C</string>
        <key>gutterForeground</key><string>#3D6070</string>
      </dict>
    </dict>

    <dict>
      <key>name</key><string>Comment</string>
      <key>scope</key><string>comment, punctuation.definition.comment</string>
      <key>settings</key><dict>
        <key>fontStyle</key><string>italic</string>
        <key>foreground</key><string>#A7BCC9</string>
      </dict>
    </dict>

    <dict>
      <key>name</key><string>String</string>
      <key>scope</key><string>string, string.quoted, punctuation.definition.string</string>
      <key>settings</key><dict><key>foreground</key><string>#7DD3C7</string></dict>
    </dict>

    <dict>
      <key>name</key><string>Regex</string>
      <key>scope</key><string>string.regexp, constant.other.character-class</string>
      <key>settings</key><dict><key>foreground</key><string>#F9A8C4</string></dict>
    </dict>

    <dict>
      <key>name</key><string>Number / Constant</string>
      <key>scope</key><string>constant.numeric, constant.other, constant.character</string>
      <key>settings</key><dict><key>foreground</key><string>#C6A36B</string></dict>
    </dict>

    <dict>
      <key>name</key><string>Language constant (true/false/null)</string>
      <key>scope</key><string>constant.language</string>
      <key>settings</key><dict><key>foreground</key><string>#A78BFA</string></dict>
    </dict>

    <dict>
      <key>name</key><string>Keyword</string>
      <key>scope</key><string>keyword, keyword.control, keyword.other</string>
      <key>settings</key><dict><key>foreground</key><string>#29B6F6</string></dict>
    </dict>

    <dict>
      <key>name</key><string>Operator</string>
      <key>scope</key><string>keyword.operator, punctuation.separator, punctuation.terminator</string>
      <key>settings</key><dict><key>foreground</key><string>#A7BCC9</string></dict>
    </dict>

    <dict>
      <key>name</key><string>Storage (var/func/class keywords)</string>
      <key>scope</key><string>storage, storage.type, storage.modifier</string>
      <key>settings</key><dict><key>foreground</key><string>#29B6F6</string></dict>
    </dict>

    <dict>
      <key>name</key><string>Function name</string>
      <key>scope</key><string>entity.name.function, support.function, meta.function-call</string>
      <key>settings</key><dict><key>foreground</key><string>#67CBFA</string></dict>
    </dict>

    <dict>
      <key>name</key><string>Type / Class</string>
      <key>scope</key><string>entity.name.class, entity.name.type, support.type, support.class, entity.other.inherited-class</string>
      <key>settings</key><dict><key>foreground</key><string>#C6A36B</string></dict>
    </dict>

    <dict>
      <key>name</key><string>Tag (HTML/XML)</string>
      <key>scope</key><string>entity.name.tag, punctuation.definition.tag</string>
      <key>settings</key><dict><key>foreground</key><string>#29B6F6</string></dict>
    </dict>

    <dict>
      <key>name</key><string>Attribute name</string>
      <key>scope</key><string>entity.other.attribute-name</string>
      <key>settings</key><dict><key>foreground</key><string>#F9A8C4</string></dict>
    </dict>

    <dict>
      <key>name</key><string>Variable</string>
      <key>scope</key><string>variable, variable.other</string>
      <key>settings</key><dict><key>foreground</key><string>#E6F4FB</string></dict>
    </dict>

    <dict>
      <key>name</key><string>Variable parameter / language (self/this)</string>
      <key>scope</key><string>variable.parameter, variable.language</string>
      <key>settings</key><dict><key>foreground</key><string>#F9A8C4</string></dict>
    </dict>

    <dict>
      <key>name</key><string>Support / built-in</string>
      <key>scope</key><string>support, support.constant, support.variable</string>
      <key>settings</key><dict><key>foreground</key><string>#67CBFA</string></dict>
    </dict>

    <dict>
      <key>name</key><string>Punctuation</string>
      <key>scope</key><string>punctuation, meta.brace, punctuation.section</string>
      <key>settings</key><dict><key>foreground</key><string>#A7BCC9</string></dict>
    </dict>

    <dict>
      <key>name</key><string>Invalid</string>
      <key>scope</key><string>invalid, invalid.illegal</string>
      <key>settings</key><dict>
        <key>foreground</key><string>#E6F4FB</string>
        <key>background</key><string>#C78490</string>
      </dict>
    </dict>

    <!-- Markdown / markup -->
    <dict>
      <key>name</key><string>Markup heading</string>
      <key>scope</key><string>markup.heading, markup.heading entity.name</string>
      <key>settings</key><dict>
        <key>fontStyle</key><string>bold</string>
        <key>foreground</key><string>#29B6F6</string>
      </dict>
    </dict>
    <dict>
      <key>name</key><string>Markup bold</string>
      <key>scope</key><string>markup.bold</string>
      <key>settings</key><dict><key>fontStyle</key><string>bold</string><key>foreground</key><string>#E6F4FB</string></dict>
    </dict>
    <dict>
      <key>name</key><string>Markup italic</string>
      <key>scope</key><string>markup.italic</string>
      <key>settings</key><dict><key>fontStyle</key><string>italic</string><key>foreground</key><string>#E6F4FB</string></dict>
    </dict>
    <dict>
      <key>name</key><string>Markup link</string>
      <key>scope</key><string>markup.underline.link, string.other.link</string>
      <key>settings</key><dict><key>foreground</key><string>#67CBFA</string></dict>
    </dict>
    <dict>
      <key>name</key><string>Markup code</string>
      <key>scope</key><string>markup.raw, markup.inline.raw, markup.fenced_code</string>
      <key>settings</key><dict><key>foreground</key><string>#7DD3C7</string></dict>
    </dict>
    <dict>
      <key>name</key><string>Markup quote</string>
      <key>scope</key><string>markup.quote</string>
      <key>settings</key><dict><key>fontStyle</key><string>italic</string><key>foreground</key><string>#A7BCC9</string></dict>
    </dict>

    <!-- Diff (also used by bat's --style=changes gutter context) -->
    <dict>
      <key>name</key><string>Diff inserted</string>
      <key>scope</key><string>markup.inserted, meta.diff.header.to-file</string>
      <key>settings</key><dict><key>foreground</key><string>#7DD3C7</string></dict>
    </dict>
    <dict>
      <key>name</key><string>Diff deleted</string>
      <key>scope</key><string>markup.deleted, meta.diff.header.from-file</string>
      <key>settings</key><dict><key>foreground</key><string>#C78490</string></dict>
    </dict>
    <dict>
      <key>name</key><string>Diff changed</string>
      <key>scope</key><string>markup.changed</string>
      <key>settings</key><dict><key>foreground</key><string>#C6A36B</string></dict>
    </dict>
    <dict>
      <key>name</key><string>Diff range</string>
      <key>scope</key><string>meta.diff.range, punctuation.definition.range.diff</string>
      <key>settings</key><dict><key>foreground</key><string>#A78BFA</string></dict>
    </dict>

  </array>
  <key>uuid</key>
  <string>a0c0ffee-1c7f-4ac0-aebf-29b6f6000000</string>
  <key>colorSpaceName</key>
  <string>sRGB</string>
</dict>
</plist>
